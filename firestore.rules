rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // users コレクション
    match /users/{userId} {
      // 認証済みユーザーのみ読み取り可能
      allow read: if request.auth != null;
      
      // 本人のみ作成・更新可能
      allow create, update: if request.auth != null 
                            && request.auth.uid == userId;
      
      // 削除は禁止
      allow delete: if false;
    }
    
    // posts コレクション
    match /posts/{postId} {
      // 認証済みユーザーのみ読み取り可能
      allow read: if request.auth != null;
      
      // 認証済みユーザーは投稿作成可能
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      
      // 誰でも更新可能（いいね・コメント追加）
      // ただし認証済みユーザーのみ
      allow update: if request.auth != null;
                    
      // 投稿者本人のみ削除可能
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.userId;
    }
    
    // posts_interval コレクション（インターバルモード用）
    match /posts_interval/{postId} {
      // 認証済みユーザーのみ読み取り可能
      allow read: if request.auth != null;
      
      // 認証済みユーザーは投稿作成可能
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      
      // 誰でも更新可能（いいね・コメント追加）
      // ただし認証済みユーザーのみ
      allow update: if request.auth != null;
                    
      // 投稿者本人のみ削除可能
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.userId;
    }
    
    // settings コレクション
    match /settings/{docId} {
      // 認証済みユーザーのみ読み取り可能
      allow read: if request.auth != null;
      
      // 認証済みユーザーのみ更新可能（6人グループなので全員が管理者）
      allow create, update: if request.auth != null;
      
      // 削除は禁止
      allow delete: if false;
    }
    
    // settings_interval コレクション（インターバルモード用）
    match /settings_interval/{docId} {
      // 認証済みユーザーのみ読み取り可能
      allow read: if request.auth != null;

      // 認証済みユーザーのみ更新可能（6人グループなので全員が管理者）
      allow create, update: if request.auth != null;

      // 削除は禁止
      allow delete: if false;
    }

    // posts_free コレクション（フリーモード用）
    match /posts_free/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.userId;
    }

    // settings_free コレクション（フリーモード用）
    match /settings_free/{docId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      // 週間チャレンジの override 無効化等、管理操作で削除が必要なため認証済みユーザーに許可
      allow delete: if request.auth != null;
    }

    // weekly_champions コレクション（歴代チャンプ記録）
    match /weekly_champions/{docId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    // weekly_challenge_history コレクション（週間チャレンジ履歴）
    match /weekly_challenge_history/{docId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    // exercise_ratings コレクション（種目評価）
    // 親ドキュメント: 集計データ（avgRating, ratingCount, ratingSum）
    // サブコレクション user_ratings: 個人の評価（本人のみ書き込み可）
    match /exercise_ratings/{exerciseKey} {
      allow read: if request.auth != null;
      // 集計ドキュメントは認証済みユーザーが書き込み可（クライアント側でバッチ更新）
      allow create, update: if request.auth != null;
      allow delete: if false;

      match /user_ratings/{userId} {
        allow read: if request.auth != null;
        // 本人のみ作成・更新可能
        allow create, update: if request.auth != null
                              && request.auth.uid == userId;
        allow delete: if false;
      }
    }
  }
}
